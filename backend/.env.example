# HELBACKUP — Environment Variables
# Copy to .env and fill in values before running outside Docker

# REQUIRED in production — generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production

# Server
PORT=3000
NODE_ENV=production

# Logging
LOG_LEVEL=info

# Database (default: /app/data/helbackup.db inside container)
# DB_PATH=/app/data/helbackup.db
